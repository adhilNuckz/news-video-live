# ─────────────────────────────────────────────────────────────
# .env — Environment Variables for AI News Streaming System
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Gemini API ─────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyAtvmuWT4hwFdKo1SuhAwoUUsibEuvSdFc

# ── RSS Feeds (comma-separated, no spaces) ─────────────────────
RSS_FEEDS=https://feeds.bbci.co.uk/news/rss.xml,https://rss.cnn.com/rss/edition.rss,https://feeds.reuters.com/reuters/topNews

# ── Paths ──────────────────────────────────────────────────────
VIDEOS_DIR=videos
AUDIO_DIR=audio
USED_NEWS_FILE=used_news.txt
VIDEOS_TXT=videos.txt

# ── Generator Loop ─────────────────────────────────────────────
# How many seconds to wait between news fetch cycles (loop mode)
LOOP_INTERVAL_SECONDS=90

# Maximum number of videos to keep on disk (older ones auto-pruned)
MAX_VIDEOS=200

# ── TTS Language ───────────────────────────────────────────────
# BCP-47 language code for gTTS (e.g. en, es, fr, de, hi)
TTS_LANG=en

# ── Web Server ─────────────────────────────────────────────────
# Address and port for the built-in Flask web player
# 0.0.0.0 = accessible from other devices on your network
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
